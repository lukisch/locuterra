{
  "name": "LOCUTERRA",
  "short_name": "LOCUTERRA",
  "description": "Gemeinwohlorientiertes, ortsbasiertes Social Network — Konzept-Demonstrator",
  "id": "/locuterra/",
  "start_url": "/locuterra/",
  "scope": "/locuterra/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "orientation": "any",
  "theme_color": "#065f46",
  "background_color": "#ffffff",
